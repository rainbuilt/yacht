{
  "manifest_version": 3,
  "name": "ChatGPT Ask Subthread Navigator",
  "description": "Turns native Ask ChatGPT follow-up turns into source-linked local subthreads.",
  "version": "0.1.0",
  "action": {
    "default_title": "Ask Subthreads",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*"
      ],
      "js": [
        "src/content/content.js"
      ],
      "css": [
        "src/content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://chatgpt.com/*"
  ],
  "permissions": [
    "activeTab",
    "storage"
  ]
}
